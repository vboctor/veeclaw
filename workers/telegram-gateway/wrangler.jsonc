{
  "name": "scaf-telegram-gateway",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-27",
  "compatibility_flags": ["nodejs_compat"],

  // Set via `wrangler secret put`:
  //   TELEGRAM_BOT_TOKEN
  //   TELEGRAM_WEBHOOK_SECRET
  //   AGENT_TOKEN (optional)

  "vars": {
    "ALLOWED_CHAT_IDS": ""
  },

  // Service binding to Agent worker
  "services": [
    { "binding": "AGENT", "service": "scaf-agent" }
  ]
}
