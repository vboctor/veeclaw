{
  "name": "veeclaw-telegram-gateway",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-27",
  "compatibility_flags": ["nodejs_compat"],

  // Set via `wrangler secret put` or `bun run setup`:
  //   TELEGRAM_BOT_TOKEN
  //   TELEGRAM_WEBHOOK_SECRET
  //   AGENT_TOKEN (optional)
  //   ALLOWED_CHAT_IDS (optional, comma-separated)

  // Service binding to Agent worker
  "services": [
    { "binding": "AGENT", "service": "veeclaw-agent" }
  ]
}
