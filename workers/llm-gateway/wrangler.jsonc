{
  "name": "scaf-llm-gateway",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-27",
  "compatibility_flags": ["nodejs_compat"],
  "rules": [
    { "type": "Text", "globs": ["**/*.md"], "fallthrough": true }
  ],
  "kv_namespaces": [
    { "binding": "MEMORY_KV", "id": "c957d678da6e4a53aedd6bc5522a1901" }
  ],

  // Service binding to scheduler worker (for schedule CRUD)
  "services": [
    { "binding": "SCHEDULER", "service": "scaf-scheduler" }
  ]
}
