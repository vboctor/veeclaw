{
  "name": "veeclaw",
  "version": "0.1.0",
  "description": "VeeClaw — Personal AI Agent on Cloudflare Workers",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "workspaces": ["packages/*", "workers/*", "workers/connectors/*"],
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch run src/index.tsx",
    "test": "bun test",
    "dev:agent": "cd workers/agent && bunx wrangler dev",
    "deploy:agent": "cd workers/agent && bunx wrangler deploy",
    "dev:gateway": "cd workers/llm-gateway && bunx wrangler dev",
    "deploy:gateway": "cd workers/llm-gateway && bunx wrangler deploy",
    "dev:telegram": "cd workers/telegram-gateway && bunx wrangler dev",
    "deploy:telegram": "cd workers/telegram-gateway && bunx wrangler deploy",
    "dev:google": "cd workers/connectors/google && bunx wrangler dev",
    "deploy:google": "cd workers/connectors/google && bunx wrangler deploy",
    "dev:github": "cd workers/connectors/github && bunx wrangler dev",
    "deploy:github": "cd workers/connectors/github && bunx wrangler deploy",
    "dev:mantishub": "cd workers/connectors/mantishub && bunx wrangler dev",
    "deploy:mantishub": "cd workers/connectors/mantishub && bunx wrangler deploy",
    "dev:todoist": "cd workers/connectors/todoist && bunx wrangler dev",
    "deploy:todoist": "cd workers/connectors/todoist && bunx wrangler deploy",
    "google-auth": "bun run scripts/google-auth.ts",
    "github-auth": "bun run scripts/github-auth.ts",
    "mantishub-auth": "bun run scripts/mantishub-auth.ts",
    "todoist-auth": "bun run scripts/todoist-auth.ts",
    "deploy": "bun run deploy:gateway && bun run deploy:google && bun run deploy:github && bun run deploy:mantishub && bun run deploy:todoist && bun run deploy:agent && bun run deploy:telegram",
    "setup": "bun run scripts/setup.ts",
    "undeploy": "bun run scripts/undeploy.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@veeclaw/shared": "workspace:*",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "15",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.4",
    "wrangler": "^4.79.0"
  }
}
